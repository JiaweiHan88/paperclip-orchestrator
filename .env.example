DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# AI Tools Bridge (Python sidecar for GitHub/Jira/Confluence/Gerrit plugin tools)
# Automatically started by `pnpm dev` when `uv` is available.
# Set to a remote URL to use a pre-running bridge instance, or set
# AI_TOOLS_BRIDGE_DISABLED=true to skip the bridge entirely.
AI_TOOLS_BRIDGE_URL=http://localhost:8000
# AI_TOOLS_BRIDGE_DISABLED=true
# AI_TOOLS_BRIDGE_PORT=8000
# BRIDGE_LOG_LEVEL=info
